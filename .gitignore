# Не добавляем в Git секретный файл с токеном бота.
.env

# Не добавляем виртуальные окружения Python.
venv/
.venv/

# Не добавляем служебные кэши Python.
__pycache__/
*.pyc
*.pyo
*.pyd

# Не добавляем файлы настроек PyCharm.
.idea/

# Не добавляем сохраненные пользователями фотографии.
img/*
!img/.gitkeep

# Не добавляем системные файлы Windows.
Thumbs.db
Desktop.ini